@page "/add"
@page "/edit/{Id:int}"
@rendermode InteractiveServer
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using FluentValidation
@using PasswordManager.Web.Data.Entities
@inject PasswordService PasswordService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<PageTitle>@(_isEdit ? "Редактировать пароль" : "Добавить пароль")</PageTitle>

<div class="form-page">
    <div class="form-header">
        <button class="btn-back" @onclick='() => Nav.NavigateTo("/passwords")'>← Назад</button>
        <h1>@(_isEdit ? "✏️ Редактировать пароль" : "➕ Добавить пароль")</h1>
    </div>

    @if (_loading)
    {
        <div class="loading-spinner">⏳ Загрузка...</div>
    }
    else
    {
        <div class="form-card">
            <EditForm Model="_entry" OnSubmit="HandleSubmit" FormName="passwordForm">
                <div class="form-group">
                    <label>Название сайта *</label>
                    <input class="form-control @(HasError("SiteName") ? "is-invalid" : "")"
                           placeholder="Например: Gmail, ВКонтакте, Сбербанк"
                           @bind="_entry.SiteName" @bind:event="oninput" />
                    <span class="field-error">@GetError("SiteName")</span>
                </div>

                <div class="form-group">
                    <label>URL сайта</label>
                    <input class="form-control @(HasError("SiteUrl") ? "is-invalid" : "")"
                           placeholder="https://mail.google.com"
                           @bind="_entry.SiteUrl" @bind:event="oninput" />
                    <span class="field-error">@GetError("SiteUrl")</span>
                </div>

                <div class="form-group">
                    <label>Логин / E-mail *</label>
                    <input class="form-control @(HasError("Username") ? "is-invalid" : "")"
                           placeholder="user@example.com"
                           @bind="_entry.Username" @bind:event="oninput" />
                    <span class="field-error">@GetError("Username")</span>
                </div>

                <div class="form-group">
                    <label>Пароль *</label>
                    <div class="password-input-group">
                        <input type="@(_showPassword ? "text" : "password")"
                               class="form-control @(HasError("Password") ? "is-invalid" : "")"
                               placeholder="Введите пароль"
                               @bind="_entry.Password" @bind:event="oninput" />
                        <button type="button" class="btn-toggle-password"
                                @onclick="() => _showPassword = !_showPassword">
                            @(_showPassword ? "🙈" : "👁")
                        </button>
                        <button type="button" class="btn-generate" @onclick="GeneratePassword" title="Сгенерировать пароль">
                            🎲
                        </button>
                    </div>
                    <span class="field-error">@GetError("Password")</span>
                </div>

                <div class="form-group">
                    <label>Категория</label>
                    <select class="form-control" @bind="_entry.CategoryId">
                        <option value="">— Без категории —</option>
                        @foreach (var cat in _categories)
                        {
                            <option value="@cat.Id">@cat.Icon @cat.Name</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label>Теги (N:N)</label>
                    @if (_tags.Any())
                    {
                        <div class="tag-selector">
                            @foreach (var tag in _tags)
                            {
                                var isSelected = _selectedTagIds.Contains(tag.Id);
                                <label class="tag-chip @(isSelected ? "selected" : "")"
                                       style="background:@(isSelected ? tag.Color : "transparent");border-color:@tag.Color;color:@(isSelected ? "white" : tag.Color)">
                                    <input type="checkbox" checked="@isSelected"
                                           @onchange="@(e => ToggleTag(tag.Id, (bool)(e.Value ?? false)))" hidden />
                                    @tag.Name
                                </label>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Тегов пока нет. <a href="/tags">Создать первый →</a></p>
                    }
                </div>

                <div class="form-group">
                    <label>Заметки</label>
                    <textarea class="form-control" rows="3"
                              placeholder="Дополнительная информация..."
                              @bind="_entry.Notes"></textarea>
                    <span class="field-error">@GetError("Notes")</span>
                </div>

                <div class="form-group form-check">
                    <input type="checkbox" id="favCheck" @bind="_entry.IsFavorite" />
                    <label for="favCheck">⭐ Добавить в избранное</label>
                </div>

                @if (_errors.Any())
                {
                    <div class="alert alert-danger">
                        <ul>
                            @foreach (var err in _errors)
                            {
                                <li>@err</li>
                            }
                        </ul>
                    </div>
                }

                @if (_success)
                {
                    <div class="alert alert-success">✅ Пароль успешно сохранён!</div>
                }

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/passwords")'>Отмена</button>
                    <button type="submit" class="btn btn-primary" disabled="@_saving">
                        @(_saving ? "⏳ Сохранение..." : (_isEdit ? "💾 Сохранить" : "➕ Добавить"))
                    </button>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private PasswordEntry _entry = new();
    private List<Category> _categories = [];
    private List<Tag> _tags = [];
    private HashSet<int> _selectedTagIds = [];
    private bool _isEdit;
    private bool _loading = true;
    private bool _saving;
    private bool _showPassword;
    private bool _success;
    private string _userId = "";
    private Dictionary<string, string> _fieldErrors = [];
    private List<string> _errors = [];

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        _userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        _categories = await PasswordService.GetCategoriesAsync(_userId);
        _tags = await PasswordService.GetTagsAsync(_userId);

        if (Id.HasValue)
        {
            _isEdit = true;
            var existing = await PasswordService.GetPasswordAsync(Id.Value, _userId);
            if (existing != null)
            {
                _entry = existing;
                _selectedTagIds = existing.Tags.Select(t => t.Id).ToHashSet();
            }
            else
            {
                Nav.NavigateTo("/passwords");
            }
        }

        _loading = false;
    }

    private void ToggleTag(int tagId, bool selected)
    {
        if (selected) _selectedTagIds.Add(tagId);
        else _selectedTagIds.Remove(tagId);
    }

    private async Task HandleSubmit()
    {
        _errors.Clear();
        _fieldErrors.Clear();

        var validator = new Validators.PasswordEntryValidator();
        var result = await validator.ValidateAsync(_entry);

        if (!result.IsValid)
        {
            foreach (var failure in result.Errors)
                _fieldErrors[failure.PropertyName] = failure.ErrorMessage;
            return;
        }

        _saving = true;
        _entry.UserId = _userId;

        PasswordEntry saved;
        if (_isEdit)
            saved = await PasswordService.UpdatePasswordAsync(_entry);
        else
            saved = await PasswordService.AddPasswordAsync(_entry);

        // Сохраняем теги (N:N)
        await PasswordService.SetPasswordTagsAsync(saved.Id, _userId, _selectedTagIds.ToList());

        _success = true;
        _saving = false;
        await Task.Delay(1000);
        Nav.NavigateTo("/passwords");
    }

    private void GeneratePassword()
    {
        const string chars = "ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnpqrstuvwxyz23456789!@#$%";
        var rng = new Random();
        _entry.Password = new string(Enumerable.Range(0, 16).Select(_ => chars[rng.Next(chars.Length)]).ToArray());
    }

    private bool HasError(string field) => _fieldErrors.ContainsKey(field);
    private string GetError(string field) => _fieldErrors.TryGetValue(field, out var e) ? e : "";
}
