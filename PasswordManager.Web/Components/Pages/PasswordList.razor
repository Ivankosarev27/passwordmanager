@page "/passwords"
@rendermode InteractiveServer
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using PasswordManager.Web.Data.Entities
@inject PasswordService PasswordService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<PageTitle>Мои пароли</PageTitle>

<div class="page-header">
    <h1>🔑 Мои пароли</h1>
    <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/add")'>➕ Добавить</button>
</div>

<div class="filter-bar">
    <input class="search-input" placeholder="🔍 Поиск по названию, логину, URL..."
           value="@_search" @oninput="OnSearch" />

    <select class="filter-select" @bind="_categoryId" @bind:after="LoadPasswords">
        <option value="">Все категории</option>
        @foreach (var cat in _categories)
        {
            <option value="@cat.Id">@cat.Icon @cat.Name</option>
        }
    </select>
</div>

@if (_loading)
{
    <div class="loading-spinner">⏳ Загрузка...</div>
}
else if (!_passwords.Any())
{
    <div class="empty-state">
        <div class="empty-icon">🔓</div>
        <h3>Паролей пока нет</h3>
        <p>Добавьте первый пароль, чтобы начать пользоваться хранилищем</p>
        <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/add")'>Добавить пароль</button>
    </div>
}
else
{
    <div class="passwords-grid">
        @foreach (var p in _passwords)
        {
            <div class="password-card">
                <div class="card-header">
                    <span class="card-icon">@(p.Category?.Icon ?? "🔑")</span>
                    <div class="card-title">
                        <strong>@p.SiteName</strong>
                        @if (!string.IsNullOrEmpty(p.SiteUrl))
                        {
                            <a href="@p.SiteUrl" target="_blank" class="site-link">↗</a>
                        }
                    </div>
                    @if (p.IsFavorite)
                    {
                        <span class="favorite-badge">⭐</span>
                    }
                </div>

                <div class="card-body">
                    <div class="field-row">
                        <label>Логин</label>
                        <span>@p.Username</span>
                    </div>
                    <div class="field-row">
                        <label>Пароль</label>
                        <span class="password-field">
                            @if (_visibleIds.Contains(p.Id))
                            {
                                <span class="password-text">@p.Password</span>
                                <button class="btn-icon" @onclick="() => ToggleVisibility(p.Id)" title="Скрыть">👁️</button>
                            }
                            else
                            {
                                <span class="password-dots">••••••••</span>
                                <button class="btn-icon" @onclick="() => ToggleVisibility(p.Id)" title="Показать">👁</button>
                            }
                            <button class="btn-icon" @onclick="() => CopyPassword(p.Password)" title="Копировать">📋</button>
                        </span>
                    </div>
                    @if (!string.IsNullOrEmpty(p.Notes))
                    {
                        <div class="field-row notes-row">
                            <label>Заметки</label>
                            <span class="notes-text">@p.Notes</span>
                        </div>
                    }
                    @if (p.Category != null)
                    {
                        <div class="field-row">
                            <label>Категория</label>
                            <span class="category-badge">@p.Category.Icon @p.Category.Name</span>
                        </div>
                    }
                </div>

                <div class="card-footer">
                    <small class="card-date">📅 @p.UpdatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                    <div class="card-actions">
                        <button class="btn btn-sm btn-secondary" @onclick="() => GoEdit(p.Id)">✏️ Изменить</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDelete(p)">🗑️ Удалить</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (_showDeleteModal && _entryToDelete != null)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>⚠️ Подтверждение удаления</h3>
            </div>
            <div class="modal-body">
                <p>Вы уверены, что хотите удалить пароль для <strong>@_entryToDelete.SiteName</strong>?</p>
                <p class="text-muted">Это действие необратимо.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">Отмена</button>
                <button class="btn btn-danger" @onclick="DeleteConfirmed">🗑️ Удалить</button>
            </div>
        </div>
    </div>
}

@if (_showCopied)
{
    <div class="toast-notification">✅ Пароль скопирован!</div>
}

@code {
    private List<PasswordEntry> _passwords = [];
    private List<PasswordManager.Web.Data.Entities.Category> _categories = [];
    private string _search = "";
    private string _categoryId = "";
    private bool _loading = true;
    private HashSet<int> _visibleIds = [];
    private bool _showDeleteModal;
    private PasswordEntry? _entryToDelete;
    private bool _showCopied;
    private string _userId = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        _userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        _categories = await PasswordService.GetCategoriesAsync(_userId);
        await LoadPasswords();
    }

    private async Task LoadPasswords()
    {
        _loading = true;
        int? catId = int.TryParse(_categoryId, out var id) ? id : null;
        _passwords = await PasswordService.GetPasswordsAsync(_userId, _search, catId);
        _loading = false;
    }

    private async Task OnSearch(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";
        await LoadPasswords();
    }

    private void ToggleVisibility(int id)
    {
        if (!_visibleIds.Remove(id))
            _visibleIds.Add(id);
    }

    private async Task CopyPassword(string password)
    {
        await Task.Delay(10); // JS interop placeholder
        _showCopied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _showCopied = false;
        StateHasChanged();
    }

    private void ConfirmDelete(PasswordEntry entry)
    {
        _entryToDelete = entry;
        _showDeleteModal = true;
    }

    private void CloseModal() => _showDeleteModal = false;

    private async Task DeleteConfirmed()
    {
        if (_entryToDelete != null)
        {
            await PasswordService.DeletePasswordAsync(_entryToDelete.Id, _userId);
            _passwords.Remove(_entryToDelete);
        }
        CloseModal();
    }

    private void GoEdit(int id) => Nav.NavigateTo($"/edit/{id}");
}
